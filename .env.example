APP_NAME="KlassCI Master"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database configuration for Master DB
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klassci_master
DB_USERNAME=root
DB_PASSWORD=

# Session and Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database

# Queue
QUEUE_CONNECTION=database

# Mail configuration (for notifications)
MAIL_MAILER=smtp
MAIL_HOST=mail.klassci.com
MAIL_PORT=465
MAIL_USERNAME=support@klassci.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=support@klassci.com
MAIL_FROM_NAME="${APP_NAME}"

# Production SSH/cPanel credentials
PRODUCTION_HOST=web44.lws-hosting.com
PRODUCTION_SSH_PORT=2083
PRODUCTION_USER=c2569688c
PRODUCTION_PATH=/home/c2569688c/public_html/

# cPanel API credentials (for automated provisioning)
CPANEL_USERNAME=c2569688c
CPANEL_API_TOKEN=
CPANEL_DOMAIN=klassci.com

# Git repository URL for KLASSCIv2
TENANT_GIT_REPO=https://github.com/yourrepo/KLASSCIv2.git
TENANT_GIT_BASE_BRANCH=presentation
